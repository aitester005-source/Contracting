# Example Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===== SUPABASE CONFIGURATION =====
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ===== OPENAI CONFIGURATION =====
# Get this from https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=sk-your_openai_api_key_here

# ===== WHATSAPP CONFIGURATION =====
# Obtained from WhatsApp Business Manager
WHATSAPP_NUMBER=971504529978
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# ===== EMAIL CONFIGURATION =====
# For Gmail: Create App Password at myaccount.google.com/apppasswords
# For other providers: Use appropriate SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ===== ADMIN CONFIGURATION =====
# Set your own secure admin API key
ADMIN_API_KEY=your_very_secure_admin_api_key_123456
ADMIN_EMAIL=admin@hedefy.ae

# ===== SITE CONFIGURATION =====
# Update based on your deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== OPTIONAL: ANALYTICS =====
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXX
